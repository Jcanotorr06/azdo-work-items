{
  "compilerOptions": {
    "target": "es2023",
    "module": "node20",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationDir": "dist",
    "types": ["node"],
  },
  "include": ["src/**/*.ts"],
  "$schema": "https://www.schemastore.org/tsconfig",
}
